<Window x:Class="WpfProyectoFinal.WinLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfProyectoFinal"
        mc:Ignorable="d"
            Title="Login - FisioZens"
    Height="590"
    Width="480"
    Icon="/imgs/logo.png"
    WindowStartupLocation="CenterScreen"
    Background="#F4F8FB">

    <Grid Margin="40">
        <Border Background="White"
            CornerRadius="15"
            Padding="30">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="FisioZens"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#0F4C81"
                       HorizontalAlignment="Center"/>

                <TextBlock Text="Inicio de Sesión"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,30"/>

                <TextBlock Text="Correo"/>
                <TextBox x:Name="txtCorreo"
                     Height="38"
                     Margin="0,5,0,15"/>

                <TextBlock Text="Contraseña"/>
                <PasswordBox x:Name="txtPassword"
                         Height="38"
                         Margin="0,5,0,20"/>
                <Button x:Name="btnIniciarSesion"
                    Content="Iniciar Sesión"
                    Height="42"
                    Background="#0F4C81"
                    Foreground="White"
                    BorderThickness="0" Click="btnIniciarSesion_Click"/>

                <Button x:Name="btnCrearCuenta"
                    Content="Crear Cuenta"
                    Height="42"
                    Margin="0,12,0,0"
                    Background="#4FC3B3"
                    Foreground="White"
                    BorderThickness="0" Click="btnCrearCuenta_Click"/>

            </StackPanel>

        </Border>
    </Grid>
</Window>
