<Window x:Class="WpfProyectoFinal.Admin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfProyectoFinal"
        mc:Ignorable="d"
        Background="#363e4f"
        Title="Admin"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Width="900"
        Icon="/imgs/logo.png">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0"
                Grid.RowSpan="5"
                CornerRadius="20"
                Background="#d9dfe3">

            <StackPanel VerticalAlignment="Stretch">

                <Image Source="/img/logo.png"
                       Margin="0,18"/>

                <TextBlock x:Name="txtNombreI"
                           Text="Bienvenido"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <Button x:Name="btnReporteA"
                        Content="🏠 Reportes"
                        Margin="10"
                        Height="32"
                        Background="#363e4f"
                        Foreground="#f6f2ef"
                        BorderThickness="0"
                        Click="btnCitasM_Click"/>

                <Button x:Name="btnFisioA"
                        Content="🧑 Fisioterapeutas"
                        Margin="10"
                        Height="32"
                        Background="#363e4f"
                        Foreground="#f6f2ef"
                        BorderThickness="0"
                        Click="btnAtencionesM_Click"/>

                <Button x:Name="btnMCerrarSesionA"
                        Content="❌ Cerrar Sesión"
                        Margin="10"
                        Height="32"
                        Background="#363e4f"
                        Foreground="#f6f2ef"
                        BorderThickness="0"
                        Click="btnMCerrarSesion_Click"/>

            </StackPanel>
        </Border>

        <StackPanel x:Name="PanelFisioterapeuta"
                    Grid.Column="1" Visibility="Visible"
                    Grid.ColumnSpan="3"
                    Grid.RowSpan="5"
                    Margin="20">

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,15">

                <Button x:Name="btnNuevoFisio"
        Content="+ Nuevo"
        Width="90"
        Height="35"
        Margin="0,0,10,0"
        Click="btnNuevo_Click"/>

                <Button x:Name="btnEditarFisio"
        Content="Actualizar"
        Width="90"
        Height="35"
        Margin="0,0,10,0"
        Click="btnEditarFisio_Click"/>

                <Button x:Name="btnEliminarFisio"
        Content="Eliminar"
        Width="90"
        Height="35"
        Margin="0,0,20,0"
        Click="btnEliminarFisio_Click"/>

                <TextBox x:Name="txtBuscarPaciente"
                         Width="220"
                         Height="35"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="btnBusquedaPac"
        Content="Buscar"
        Width="90"
        Height="35"
        Background="#8ea39d"
        Foreground="White"
        Click="btnBusquedaPac_Click"/>

            </StackPanel>

            <DataGrid x:Name="dgHistorialPac"
          Height="180"
          Background="White"
          AutoGenerateColumns="False"
          Margin="0,0,0,20"
          SelectionChanged="dgHistorialPac_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nombre"
                            Binding="{Binding Nombre}"
                            Width="170"/>

                    <DataGridTextColumn Header="Especialidad"
                            Binding="{Binding Especialidad}"
                            Width="130"/>

                    <DataGridTextColumn Header="Teléfono"
                            Binding="{Binding Telefono}"
                            Width="120"/>

                    <DataGridTextColumn Header="Correo"
                            Binding="{Binding Correo}"
                            Width="180"/>

                </DataGrid.Columns>

            </DataGrid>

            <Border Background="#455066"
                    Padding="20"
                    CornerRadius="10">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>

                    <Label Content="Nombre" Margin="10,0"
                           Foreground="White"/>

                    <TextBox x:Name="tbNombre"
                             Grid.Column="1" Background="#d9dfe3"
                             Height="25"/>

                    <Label Content="Apellido" Margin="10,0"
                           Foreground="White"
                           Grid.Column="2"/>

                    <TextBox x:Name="tbApellido" Background="#d9dfe3"
                             Grid.Column="3" 
                             Height="25"/>

                    <Label Content="Especialidad"
                           Foreground="White"
                           Grid.Row="1"/>

                    <ComboBox Grid.Row="1" x:Name="cbEspecialidad"
                              Grid.Column="1"
                              Height="25">

                        <ComboBoxItem Content="Rehabilitación"/>
                        <ComboBoxItem Content="Deportiva"/>
                        <ComboBoxItem Content="Neurológica"/>

                    </ComboBox>

                    <Label Content="Teléfono"
                           Foreground="White"
                           Grid.Row="1" Margin="10,0"
                           Grid.Column="2"/>

                    <TextBox x:Name="tbTelefono"
                             Grid.Row="1"
                             Grid.Column="3" Background="#d9dfe3"
                             Height="25"/>

                    <Label Content="Correo"
                           Foreground="White"
                           Grid.Row="2"/>

                    <TextBox x:Name="tbCorreo"
                             Grid.Row="2"
                             Grid.Column="1" Background="#d9dfe3"
                             Height="25"/>

                    <Button x:Name="btnGuardar"
                            Content="Guardar"
                            Grid.Row="4" Background="#8ea39d"
                            Grid.Column="1"
                            Margin="0,10,10,0" Click="btnGuardar_Click"/>

                    <Button x:Name="btLimpiar" Background="#8ea39d"
                            Content="Limpiar"
                            Grid.Row="4"
                            Grid.Column="3"
                            Margin="0,10,10,0" Height="30" VerticalAlignment="Top" Click="btLimpiar_Click"/>

                </Grid>
            </Border>
        </StackPanel>

        <StackPanel x:Name="PanelReportes" Visibility="Hidden" Grid.Column="1" Grid.ColumnSpan="3" Grid.RowSpan="5" Margin="20">

            <TextBlock Text="Reportes" FontSize="22" Foreground="White" Width="654" Height="56"/>

            <Border Background="#455066" CornerRadius="10" Padding="20" Width="643">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <Label Content="Mes" Foreground="White"/>

                    <ComboBox x:Name="cbMes" Grid.Column="1" Height="25">
                        <ComboBoxItem Content="Enero"/>
                        <ComboBoxItem Content="Febrero"/>
                        <ComboBoxItem Content="Marzo"/>
                        <ComboBoxItem Content="Abril"/>
                        <ComboBoxItem Content="Mayo"/>
                        <ComboBoxItem Content="Junio"/>
                        <ComboBoxItem Content="Julio"/>
                        <ComboBoxItem Content="Agosto"/>
                        <ComboBoxItem Content="Septiembre"/>
                        <ComboBoxItem Content="Octubre"/>
                        <ComboBoxItem Content="Noviembre"/>
                        <ComboBoxItem Content="Diciembre"/>
                    </ComboBox>

                    <Label Content="Año" Grid.Column="2" Foreground="White"/>

                    <ComboBox x:Name="cbAnio" Grid.Column="3" Height="25">
                        <ComboBoxItem Content="2024"/>
                        <ComboBoxItem Content="2025"/>
                        <ComboBoxItem Content="2026"/>
                    </ComboBox>

                    <Button x:Name="btnGenerarReporte"
        Content="Generar reporte"
        Grid.Row="1"
        Grid.Column="1"
        Grid.ColumnSpan="2"
        Width="180"
        Height="35"
        Margin="0,10,0,0"
        Background="#8ea39d"
        Foreground="White"
        Click="btnGenerarReporte_Click"/>
                </Grid>

            </Border>
            <StackPanel Orientation="Horizontal" Height="173" Width="593">

                <Border Width="130" Height="80" Margin="0,0,15,0" Background="#8ea39d" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="" x:Name="tbCitas" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total citas" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Width="130" Height="80" Margin="0,0,15,0" Background="#8ea39d" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="" x:Name="tbPacientes" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pacientes" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Width="130" Height="80" Margin="0,0,15,0" Background="#8ea39d" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="10" x:Name="tbFisio" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Fisioterapeutas" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Width="130" Height="80" Background="#8ea39d" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="tbIngresos" Text="" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Ingresos" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

        </StackPanel>


    </Grid>
</Window>