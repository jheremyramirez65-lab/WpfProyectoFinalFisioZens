<Window x:Class="WpfProyectoFinal.WinSignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfProyectoFinal"
        mc:Ignorable="d"
            Title="Registro - FisioZens"
    Height="800"
    Width="520"
    Icon="/imgs/logo.png"
    WindowStartupLocation="CenterScreen"
    Background="#F4F8FB">

    <Grid Margin="35">
        <Border Background="White"
            CornerRadius="15"
            Padding="30">

            <StackPanel>

                <TextBlock Text="Crear Cuenta"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#0F4C81"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

                <TextBlock Text="Nombre"/>
                <TextBox x:Name="txtNombre" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="Usuario"/>
                <TextBox x:Name="txtNombreUsuario" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="Apellido"/>
                <TextBox x:Name="txtApellido" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="Contraseña"/>
                <PasswordBox x:Name="txtPassword" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="Celular"/>
                <TextBox x:Name="txtCelular" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="Correo"/>
                <TextBox x:Name="txtCorreo" Height="36" Margin="0,5,0,10"/>

                <TextBlock Text="País"/>
                <ComboBox x:Name="cbPais" Height="36" Margin="0,5,0,10">
                    <ComboBoxItem Content="Bolivia"/>
                    <ComboBoxItem Content="Argentina"/>
                    <ComboBoxItem Content="Chile"/>
                </ComboBox>

                <TextBlock Text="Género"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                    <RadioButton x:Name="rbMasculino" Content="Masculino" Margin="0,0,15,0"/>
                    <RadioButton x:Name="rbFemenino" Content="Femenino" Margin="0,0,15,0"/>
                    <RadioButton x:Name="rbOtro" Content="Otro"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnRegistrar"
                        Content="Registrar"
                        Width="120"
                        Height="40"
                        Background="#4FC3B3"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="5"
                        Click="btnRegistrar_Click"/>

                    <Button x:Name="brnCancelar"
                        Content="Cancelar"
                        Width="120"
                        Height="40"
                        Background="#C0392B"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="5"
                        Click="btnCancelar_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
