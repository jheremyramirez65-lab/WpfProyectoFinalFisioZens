<UserControl x:Class="WpfProyectoFinal.Atenciones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfProyectoFinal"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Background="AliceBlue" Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <TextBlock Text="Nueva Atención"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Paciente"/>
            <ComboBox x:Name="cbPaciente"
                      Height="34"
                      Margin="0,5,0,10"
                      DisplayMemberPath="NombreCompleto"
                      SelectedValuePath="IdPaciente"/>

            <TextBlock Text="Fisioterapeuta disponible"/>
            <ComboBox x:Name="cbFisioterapeuta"
                      Height="34"
                      Margin="0,5,0,10"
                      DisplayMemberPath="NombreCompleto"
                      SelectedValuePath="IdFisioterapeuta"/>

            <TextBlock Text="Tratamiento"/>
            <ComboBox x:Name="cbTratamiento"
                      Height="34"
                      Margin="0,5,0,10"
                      DisplayMemberPath="NombreTratamiento"
                      SelectedValuePath="IdTratamiento"/>

            <TextBlock Text="Observación"/>
            <TextBox x:Name="txtObservacion"
                     Height="60"
                     Margin="0,5,0,10"
                     TextWrapping="Wrap"/>

            <Button x:Name="btnGuardarAtencion"
                    Content="Guardar Atención"
                    Height="40"
                    Background="#0F4C81"
                    Foreground="White"
                    Click="btnGuardarAtencion_Click"/>

            <DataGrid x:Name="dgAtenciones"
                      Height="170"
                      Margin="0,15,0,0"
                      AutoGenerateColumns="True"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
